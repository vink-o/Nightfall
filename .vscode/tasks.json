{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build Nightfall Project",
            "command": ".\\build.bat", 
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe:",
                "${workspaceFolder}\\Nightfall.exe",
                "${workspaceFolder}\\*.cpp"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}